<header class="wk-topbar">
  <button class="wk-burger" id="wk-burger" aria-label="Toggle sidebar" title="Toggle sidebar (⌘\)">☰</button>
  <a href="{{WIKI_BASE}}/" class="wk-brand">wikia <span class="dim">· knowledge</span></a>
  <div class="wk-spacer"></div>
  <button class="wk-search-btn" id="wk-search-btn" title="Buscar (⌘K)">
    <span>⌕</span><span>Buscar</span>
    <span class="kbd">⌘ K</span>
  </button>
  <div class="wk-width-toggle" role="group" aria-label="Reading width">
    <button data-width="compact" class="active" title="Compact reading (720px)" aria-label="Compact">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="4.5" y="2.5" width="7" height="11" rx="0.5"/>
      </svg>
    </button>
    <button data-width="wide" title="Wide reading (960px)" aria-label="Wide">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="1.5" y="2.5" width="13" height="11" rx="0.5"/>
      </svg>
    </button>
  </div>
</header>
